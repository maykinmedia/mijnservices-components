{
  "name": "@mijnservices/card-as-link",
  "version": "0.1.0",
  "description": "React CardAsLink component for the MijnServices component library",
  "license": "EUPL-1.2",
  "author": "Maykin Media",
  "type": "module",
  "main": "./dist/card-as-link.cjs",
  "module": "./dist/card-as-link.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/card-as-link.js",
      "require": "./dist/card-as-link.cjs"
    },
    "./index.css": "./dist/card-as-link.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "rimraf": "^6.0.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  }
}
